# VITE_API_BASE_URL: Spring Boot backend base URL for policy search/detail APIs.
# Defaults to same-origin Nginx proxy when omitted.
# Local direct-backend example: http://localhost:8080
VITE_API_BASE_URL=""

# VITE_CHATBOT_API_BASE_URL: FastAPI chatbot base URL.
# Defaults to same-origin Nginx proxy when omitted.
# Local direct-chatbot example: http://localhost:8000
VITE_CHATBOT_API_BASE_URL=""
